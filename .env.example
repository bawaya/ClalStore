# ═══════════════════════════════════════════════════════
# ClalMobile — Environment Variables (54 vars)
# انسخ هذا الملف إلى .env.local وعبّي القيم
# ═══════════════════════════════════════════════════════

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
DATABASE_URL=

# ── App URLs (use NEXT_PUBLIC_APP_URL; SITE_URL is legacy fallback only) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Master key used to encrypt secrets stored in integration_secrets.
INTEGRATIONS_MASTER_KEY=

# ── AI — Anthropic Claude ──
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_ADMIN=
ANTHROPIC_API_KEY_BOT=
ANTHROPIC_API_KEY_STORE=
# Optional: override model for /api/webchat/product-assistant (default: claude-sonnet-4-20250514)
# ANTHROPIC_PRODUCT_ASSISTANT_MODEL=

# ── Privacy Protection Law Amendment 13 ──
# Salt added to client IP before SHA-256 hashing in consent_log (audit trail).
# Set any random secret string. Required in production for compliant audit storage.
IP_HASH_SALT=

# ── AI — OpenAI ──
OPENAI_API_KEY=
OPENAI_API_KEY_ADMIN=
OPENAI_API_KEY_PRICES=

# ── AI — Google Gemini ──
GEMINI_API_KEY=

# ── Payment — Rivhit / iCredit ──
ICREDIT_GROUP_PRIVATE_TOKEN=
ICREDIT_TEST_MODE=false
RIVHIT_API_KEY=

# ── Payment — UPay ──
UPAY_API_KEY=
UPAY_API_USERNAME=

# ── Payment Webhooks ──
PAYMENT_WEBHOOK_SECRET=

# ── WhatsApp — YCloud ──
YCLOUD_API_KEY=
WHATSAPP_PHONE_ID=
WEBHOOK_SECRET=
WEBHOOK_VERIFY_TOKEN=

# ── SMS — Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=

# ── Email — SendGrid ──
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@clalmobile.com

# ── Email — Resend ──
RESEND_API_KEY=
RESEND_FROM=
RESEND_WEBHOOK_SECRET=

# ── Cloudflare R2 Storage ──
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Push Notifications (VAPID) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@clalmobile.com

# ── Image Services ──
REMOVEBG_API_KEY=
PEXELS_API_KEY=

# ── Device Data ──
MOBILEAPI_KEY=

# ── Monitoring / API smoke (Postman: healthCheckToken) ──
HEALTH_CHECK_TOKEN=

# ── Cron Jobs ──
CRON_SECRET=

# ── Contact / Team ──
CONTACT_EMAIL=
ADMIN_PERSONAL_PHONE=
TEAM_WHATSAPP_NUMBERS=

# ===== MobileAPI.dev (Device Specs) =====
MOBILEAPI_KEY=your-mobileapi-key

# ===== Supabase Management API =====
# Personal Access Token — أنشئه من: https://supabase.com/dashboard/account/tokens
# يمنح وصول ثابت بدون supabase login يدوي كل مرة
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token

# ── Weekly WhatsApp Summary (scripts/weekly-employee-summary.ts) ──
# Set to "false" to actually send messages; any other value (or unset)
# keeps the script in dry-run mode (console logs only).
WEEKLY_SUMMARY_DRY_RUN=true
