# ============================================
# ClalMobile — Environment Variables
# ============================================
# انسخ هذا الملف إلى .env.local وعبّي القيم

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ClalMobile
NEXT_PUBLIC_SITE_URL=https://clalmobile.com

# ===== Payment (iCredit / Rivhit) =====
# Get GroupPrivateToken from iCredit: Payment Pages > Edit > Payment Settings > מזהה דף תשלום
ICREDIT_GROUP_PRIVATE_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ICREDIT_TEST_MODE=false

# ===== WhatsApp (yCloud) =====
YCLOUD_API_KEY=your-ycloud-api-key
WHATSAPP_PHONE_ID=+972XXXXXXXXX  # must be the actual phone number registered in yCloud (NOT the WABA ID)
WEBHOOK_VERIFY_TOKEN=generate-a-random-token

# ===== SMS / OTP (Twilio) =====
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid
TWILIO_FROM_NUMBER=+972XXXXXXXXX

# ===== Email (Resend — recommended) =====
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=ClalMobile <noreply@clalmobile.com>

# ===== Email (SendGrid — alternative) =====
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@clalmobile.com

# ===== AI — Anthropic Claude =====
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_KEY_BOT=your-bot-specific-key-or-leave-blank
ANTHROPIC_API_KEY_ADMIN=your-admin-specific-key-or-leave-blank
ANTHROPIC_API_KEY_STORE=your-store-specific-key-or-leave-blank

# ===== AI — OpenAI (admin product descriptions) =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEY_ADMIN=your-admin-openai-key-or-leave-blank

# ===== Cloudflare R2 (Media Storage) =====
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=clalmobile-images
R2_PUBLIC_URL=https://your-r2-public-url.com

# ===== Image Processing =====
REMOVEBG_API_KEY=your-removebg-api-key

# ===== Device Specs API =====
MOBILEAPI_KEY=your-mobileapi-key

# ===== Pexels (Product Image Search) =====
PEXELS_API_KEY=your-pexels-api-key

# ===== Push Notifications (Web Push) =====
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-base64
VAPID_PRIVATE_KEY=your-vapid-private-key-base64

# ===== Notifications =====
TEAM_WHATSAPP_NUMBERS=0541234567,0549876543
ADMIN_REPORT_PHONE=+972XXXXXXXXX
ADMIN_PERSONAL_PHONE=+972XXXXXXXXX

# ===== Cron / Scheduled Tasks =====
CRON_SECRET=generate-a-secure-random-string

# ===== Analytics (optional, configured in admin) =====
# GA4 and Meta Pixel are configured via admin dashboard
