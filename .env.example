# ============================================
# ClalMobile — Environment Variables
# ============================================
# انسخ هذا الملف إلى .env.local وعبّي القيم

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ClalMobile

# ===== Payment (Rivhit) — Season 6 ✅ =====
RIVHIT_API_KEY=your-rivhit-api-key
RIVHIT_BUSINESS_ID=your-rivhit-business-id

# ===== WhatsApp (yCloud) — Season 4 ✅ =====
YCLOUD_API_KEY=your-ycloud-api-key
WHATSAPP_PHONE_ID=your-whatsapp-business-phone-id
WEBHOOK_VERIFY_TOKEN=generate-a-random-token
# Comma-separated phone numbers for order alerts
TEAM_WHATSAPP_NUMBERS=0541234567,0549876543

# ===== SMS / OTP (Twilio) =====
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid

# ===== Email (SendGrid) — Season 6 ✅ =====
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@clalmobile.com

# ===== MobileAPI.dev (Device Specs) =====
MOBILEAPI_KEY=your-mobileapi-key

# ===== Email (Resend) — Primary =====
RESEND_API_KEY=your-resend-api-key

# ===== AI (Anthropic Claude) =====
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_KEY_BOT=your-anthropic-bot-key
ANTHROPIC_API_KEY_ADMIN=your-anthropic-admin-key
ANTHROPIC_API_KEY_STORE=your-anthropic-store-key

# ===== AI (OpenAI) =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_KEY_ADMIN=your-openai-admin-key

# ===== Image Processing =====
REMOVEBG_API_KEY=your-removebg-api-key

# ===== Cloudflare R2 Storage =====
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=clalmobile
R2_PUBLIC_URL=https://your-r2-public-url

# ===== Push Notifications (VAPID) =====
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ===== Cron Security =====
CRON_SECRET=generate-a-strong-random-secret

# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://clalmobile.com
CONTACT_EMAIL=info@clalmobile.com

# ===== Media (Pexels) =====
PEXELS_API_KEY=your-pexels-api-key
